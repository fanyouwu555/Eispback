<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.aeisp.template.mapper.TplTemplatePreviewImageMapper">

    <select id="selectByTemplateId" resultType="com.aeisp.template.entity.TplTemplatePreviewImage">
        SELECT *
        FROM tpl_template_preview_image
        WHERE template_id = #{templateId}
          AND deleted = 0
        ORDER BY sort_order ASC, created_at DESC
    </select>

</mapper>
