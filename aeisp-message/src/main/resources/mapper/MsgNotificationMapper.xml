<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.aeisp.message.mapper.MsgNotificationMapper">

    <resultMap id="BaseResultMap" type="com.aeisp.message.entity.MsgNotification">
        <id column="id" property="id"/>
        <result column="title" property="title"/>
        <result column="content" property="content"/>
        <result column="summary" property="summary"/>
        <result column="msg_type" property="msgType"/>
        <result column="push_scope" property="pushScope"/>
        <result column="push_target" property="pushTarget"/>
        <result column="push_type" property="pushType"/>
        <result column="push_time" property="pushTime"/>
        <result column="expire_time" property="expireTime"/>
        <result column="status" property="status"/>
        <result column="is_top" property="isTop"/>
        <result column="read_count" property="readCount"/>
        <result column="total_count" property="totalCount"/>
        <result column="priority" property="priority"/>
        <result column="channels" property="channels"/>
        <result column="target_user_ids" property="targetUserIds"/>
        <result column="target_group_ids" property="targetGroupIds"/>
        <result column="need_read_confirmation" property="needReadConfirmation"/>
        <result column="target_count" property="targetCount"/>
        <result column="success_count" property="successCount"/>
        <result column="failed_count" property="failedCount"/>
        <result column="sent_at" property="sentAt"/>
        <result column="revoked_at" property="revokedAt"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
        <result column="created_by" property="createdBy"/>
        <result column="updated_by" property="updatedBy"/>
        <result column="deleted" property="deleted"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, title, content, summary, msg_type, push_scope, push_target, push_type, push_time, expire_time,
        status, is_top, read_count, total_count, priority, channels, target_user_ids, target_group_ids,
        need_read_confirmation, target_count, success_count, failed_count, sent_at, revoked_at,
        created_at, updated_at, created_by, updated_by, deleted
    </sql>

    <!-- 查询用户未读消息列表；status = 2 对应已发送状态，read_status = 1 对应未读 -->
    <select id="selectUnreadByUserId" resultMap="BaseResultMap">
        SELECT
            <include refid="Base_Column_List"/>
        FROM msg_notification n
        INNER JOIN msg_user_notification un ON n.id = un.notification_id
        WHERE un.user_id = #{userId}
          AND un.read_status = 1
          AND n.deleted = 0
          AND n.status = 2
        ORDER BY n.is_top DESC, n.push_time DESC
    </select>

    <!-- 查询用户未读消息数量；status = 2 对应已发送状态，read_status = 1 对应未读 -->
    <select id="selectUnreadCountByUserId" resultType="java.lang.Long">
        SELECT COUNT(*)
        FROM msg_notification n
        INNER JOIN msg_user_notification un ON n.id = un.notification_id
        WHERE un.user_id = #{userId}
          AND un.read_status = 1
          AND n.deleted = 0
          AND n.status = 2
    </select>

    <!-- 查询已到推送时间的定时消息；push_type = 2 对应定时推送，status = 1 对应草稿状态 -->
    <select id="selectClientAnnouncements" resultMap="BaseResultMap">
        SELECT
            <include refid="Base_Column_List"/>
        FROM msg_notification
        WHERE status = 2
          AND (expire_time IS NULL OR expire_time &gt; NOW())
          AND deleted = 0
        ORDER BY is_top DESC, push_time DESC
    </select>

    <select id="selectScheduledNotificationsToPush" resultMap="BaseResultMap">
        SELECT
            <include refid="Base_Column_List"/>
        FROM msg_notification
        WHERE push_type = 2
          AND status = 1
          AND push_time &lt;= NOW()
          AND deleted = 0
        ORDER BY push_time ASC
    </select>

    <!-- 将已发送但已过期的公告标记为已过期；status = 2 已发送，status = 6 已过期 -->
    <update id="markExpired">
        UPDATE msg_notification
        SET status = 6
        WHERE status = 2
          AND expire_time IS NOT NULL
          AND expire_time &lt; #{now}
          AND deleted = 0
    </update>

</mapper>
