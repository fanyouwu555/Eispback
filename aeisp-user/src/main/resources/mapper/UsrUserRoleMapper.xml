<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.aeisp.user.mapper.UsrUserRoleMapper">

    <resultMap id="BaseResultMap" type="com.aeisp.user.entity.UsrUserRole">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="role_id" property="roleId"/>
        <result column="granted_by" property="grantedBy"/>
        <result column="granted_at" property="grantedAt"/>
        <result column="created_at" property="createdAt"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, user_id, role_id, granted_by, granted_at, created_at
    </sql>

    <select id="selectRoleIdsByUserId" resultType="java.lang.Long">
        SELECT role_id
        FROM usr_user_role
        WHERE user_id = #{userId}
    </select>

    <insert id="batchInsert">
        INSERT INTO usr_user_role
        (user_id, role_id, granted_by, granted_at, created_at)
        VALUES
        <foreach collection="list" item="item" separator=",">
            (#{item.userId}, #{item.roleId}, #{item.grantedBy}, #{item.grantedAt}, #{item.createdAt})
        </foreach>
    </insert>

</mapper>
