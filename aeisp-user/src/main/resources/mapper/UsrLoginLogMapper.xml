<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.aeisp.user.mapper.UsrLoginLogMapper">

    <resultMap id="BaseResultMap" type="com.aeisp.user.entity.UsrLoginLog">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="login_account" property="loginAccount"/>
        <result column="login_type" property="loginType"/>
        <result column="login_result" property="loginResult"/>
        <result column="ip_address" property="ipAddress"/>
        <result column="device_type" property="deviceType"/>
        <result column="os_info" property="osInfo"/>
        <result column="browser_info" property="browserInfo"/>
        <result column="device_id" property="deviceId"/>
        <result column="created_at" property="createdAt"/>
    </resultMap>

    <select id="countActiveUsers" resultType="java.lang.Long">
        SELECT COUNT(DISTINCT user_id)
        FROM usr_login_log
        WHERE login_result = 1
          AND created_at &gt;= #{start}
          AND created_at &lt;= #{end}
    </select>

    <select id="countAllActiveUsers" resultType="java.lang.Long">
        SELECT COUNT(DISTINCT user_id)
        FROM usr_login_log
        WHERE login_result = 1
    </select>

</mapper>
