<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.aeisp.recharge.mapper.UsrBalanceChangeLogMapper">

    <select id="selectByUserId" resultType="com.aeisp.recharge.entity.UsrBalanceChangeLog">
        SELECT *
        FROM usr_balance_change_log
        WHERE user_id = #{userId}
        ORDER BY created_at DESC
    </select>

</mapper>
