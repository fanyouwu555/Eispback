<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.aeisp.recharge.mapper.DurationPackageMapper">

    <select id="selectActiveList" resultType="com.aeisp.recharge.entity.DurationPackage">
        SELECT *
        FROM duration_package
        WHERE status = 1
          AND deleted = 0
        ORDER BY sort_order ASC, created_at DESC
    </select>

</mapper>
