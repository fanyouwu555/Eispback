<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.aeisp.recharge.mapper.RechargeOrderMapper">

    <select id="selectByOrderNo" resultType="com.aeisp.recharge.entity.RechargeOrder">
        SELECT *
        FROM recharge_order
        WHERE order_no = #{orderNo}
          AND deleted = 0
    </select>

    <select id="selectByUserId" resultType="com.aeisp.recharge.entity.RechargeOrder">
        SELECT *
        FROM recharge_order
        WHERE user_id = #{userId}
          AND deleted = 0
        ORDER BY created_at DESC
    </select>

</mapper>
