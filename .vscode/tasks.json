{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Maven Clean Install (Full Build)",
            "type": "shell",
            "command": "mvn",
            "args": [
                "clean",
                "install"
            ],
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "new"
            },
            "problemMatcher": "$msCompile"
        },
        {
            "label": "Maven Build (Skip Tests)",
            "type": "shell",
            "command": "mvn",
            "args": [
                "clean",
                "install",
                "-DskipTests"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "silent",
                "panel": "shared"
            },
            "problemMatcher": "$msCompile"
        },
        {
            "label": "Maven Compile Only",
            "type": "shell",
            "command": "mvn",
            "args": [
                "compile"
            ],
            "group": "build",
            "presentation": {
                "reveal": "silent",
                "panel": "shared"
            },
            "problemMatcher": "$msCompile"
        }
    ]
}
